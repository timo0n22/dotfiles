# Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(git zsh-autosuggestions zsh-vi-mode)

source $ZSH/oh-my-zsh.sh

# XDG
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Editor
export EDITOR='nvim'
export VISUAL='nvim'

# Path
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

# Aliases — editor
alias vim='nvim'
alias vi='nvim'

# Aliases — ls/eza
alias ls="eza --icons=always --color=always"
alias l="eza -lh --icons=always --color=always"
alias ll="eza -lah --icons=always --color=always"
alias la="eza -lah --icons=always --color=always"
alias lt="eza --tree --icons=always --color=always"
alias lT="eza --tree --icons=always --color=always -a"

# Aliases — cat/bat
alias cat='bat'

# Aliases — navigation
alias cd="z"

# Aliases — git
alias gc="git commit -m"
alias gp="git push origin HEAD"
alias gpu="git pull"
alias gst="git status"
alias glog="git log --oneline --graph --decorate"
alias gd="git diff"

# Aliases — yabai/skhd/sketchybar
alias ystart="yabai --start-service"
alias ystop="yabai --stop-service"
alias skstart="brew services start sketchybar"
alias skstop="brew services stop sketchybar"

# Aliases — tmux
alias ta="tmux attach || tmux"
alias tls="tmux ls"
alias tn="tmux new -s"

# Aliases — system
alias grep="grep --color=auto"
alias ..="cd .."
alias ...="cd ../.."

# FZF
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude .git --exclude node_modules --exclude .cache"
export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
--color=selected-bg:#45475a \
--multi"
source <(fzf --zsh)

# Zoxide
eval "$(zoxide init zsh)"

# Atuin
eval "$(atuin init zsh)"

# Yazi — cd on exit
function yy() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# Syntax highlighting (catppuccin)
[[ -f ~/.config/zsh/zsh-syntax-highlighting/themes/catppuccin_mocha-zsh-syntax-highlighting.zsh ]] && \
  source ~/.config/zsh/zsh-syntax-highlighting/themes/catppuccin_mocha-zsh-syntax-highlighting.zsh
source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh 2>/dev/null

# Powerlevel10k
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
