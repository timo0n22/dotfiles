#!/bin/bash
# daily - Create or open today's note

NOTES_DIR="$HOME/notes/daily"
TODAY=$(date +%Y-%m-%d)
FILE="$NOTES_DIR/$TODAY.md"

if [ ! -f "$FILE" ]; then
    cat > "$FILE" << EOF
# $(date '+%A, %B %d, %Y')

## What I learned today



## What I built today



## Problems solved



## Tomorrow's focus



## Notes
- 

EOF
fi

nvim "$FILE"
