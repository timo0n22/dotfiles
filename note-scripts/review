#!/bin/bash
# review - Spaced repetition review

NOTES_DIR="$HOME/notes"
REVIEW_FILE="$NOTES_DIR/.review-schedule"

# Find notes that need review
TODAY=$(date +%Y-%m-%d)

# Show notes to review
echo "=== Notes to review today ==="
grep "$TODAY" "$REVIEW_FILE" 2>/dev/null | while read line; do
    NOTE=$(echo "$line" | cut -d: -f2)
    echo "$NOTE"
done

# Interactive review
find "$NOTES_DIR" -name "*.md" | \
    fzf --multi --preview 'bat --color=always {}' | \
    while read note; do
        nvim "$note"
        read -p "Next review in (1=tomorrow, 3=3days, 7=week, 30=month): " DAYS
        NEXT=$(date -v+${DAYS}d +%Y-%m-%d)
        echo "$NEXT:$note" >> "$REVIEW_FILE"
    done
