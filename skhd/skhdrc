### skhd config

## Focus windows
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

## Swap windows
ctrl + alt - h : yabai -m window --swap west
ctrl + alt - j : yabai -m window --swap south
ctrl + alt - k : yabai -m window --swap north
ctrl + alt - l : yabai -m window --swap east

## Mirror layout
shift + alt - y : yabai -m space --mirror y-axis
shift + alt - r : yabai -m space --mirror x-axis

## Toggle float
ctrl + alt - t : yabai -m window --toggle float
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

## Open terminal (Alacritty)
cmd - return : open -n -a "Alacritty"

## Open Zen browser
cmd + shift - return : open -n -a "Zen"

## Resize windows
fn - h : yabai -m window --resize left:-50:0; yabai -m window --resize right:-50:0
fn - j : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
fn - k : yabai -m window --resize top:0:-50; yabai -m window --resize bottom:0:-50
fn - l : yabai -m window --resize right:50:0; yabai -m window --resize left:50:0

## Balance layout
shift + alt - return : yabai -m space --balance

## Fullscreen
ctrl + alt - return : yabai -m window --toggle zoom-fullscreen
shift + alt - f : yabai -m window --toggle native-fullscreen

## Rotate layout
shift + alt - p : yabai -m space --rotate 270
ctrl + alt - r : yabai -m space --rotate 90

## Layout mode
alt - f : yabai -m space --layout float
alt - g : yabai -m space --layout bsp

## Focus space
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5
cmd - 6 : yabai -m space --focus 6
cmd - 7 : yabai -m space --focus 7
cmd - 8 : yabai -m space --focus 8
cmd - 9 : yabai -m space --focus 9
cmd - 0 : yabai -m space --focus 10

## Send window to space
cmd + shift - 1 : yabai -m window --space 1
cmd + shift - 2 : yabai -m window --space 2
cmd + shift - 3 : yabai -m window --space 3
cmd + shift - 4 : yabai -m window --space 4
cmd + shift - 5 : yabai -m window --space 5
cmd + shift - 6 : yabai -m window --space 6
cmd + shift - 7 : yabai -m window --space 7
cmd + shift - 8 : yabai -m window --space 8
cmd + shift - 9 : yabai -m window --space 9
cmd + shift - 0 : yabai -m window --space 10

## Window layers
ctrl + alt - o : yabai -m window --toggle layer
ctrl + alt + shift - o : yabai -m window --layer below

## Sticky window
ctrl + alt - s : yabai -m window --toggle sticky
